    </mxCell>

    <!-- ══════════════════════════════════════════════
         STAGE 2 — NORMALIZATION
    ══════════════════════════════════════════════ -->
    <mxCell id="stage2" value="&lt;b&gt;Stage 2&lt;/b&gt;&lt;br&gt;NORMALIZATION LAYER&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Pure functions per field:&lt;br&gt;• E.164 phones&lt;br&gt;• ISO-3166 countries&lt;br&gt;• YYYY-MM dates&lt;br&gt;• Skill taxonomy&lt;br&gt;• Null sentinel rejection&lt;br&gt;Returns (value, conf, method)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#e94560;fontColor=#ffffff;fontSize=12;arcSize=10;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="510" y="200" width="170" height="180" as="geometry" />
    </mxCell>

    <!-- ══════════════════════════════════════════════
