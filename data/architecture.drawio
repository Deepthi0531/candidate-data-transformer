    <mxCell id="stage3" value="&lt;b&gt;Stage 3&lt;/b&gt;&lt;br&gt;IDENTITY BROKER&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Email-keyed registry.&lt;br&gt;Exact normalized match.&lt;br&gt;No email → new entity.&lt;br&gt;Tolerates name variants.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#e94560;fontColor=#ffffff;fontSize=12;arcSize=10;verticalAlign=top;" vertex="1" parent="1">
      <mxGeometry x="750" y="200" width="160" height="140" as="geometry" />
