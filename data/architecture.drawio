    <mxCell id="stage1" value="&lt;b&gt;Stage 1&lt;/b&gt;&lt;br&gt;INGESTION LAYER&lt;br&gt;&lt;font style=&quot;font-size:10px&quot;&gt;Generator-based adapters&lt;br&gt;per source type.&lt;br&gt;Streams records 1-by-1.&lt;br&gt;Skips malformed inputs.&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#e94560;fontColor=#ffffff;fontSize=12;arcSize=10;verticalAlign=top;" vertex="1" parent="1">
